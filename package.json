{
    "name": "reservas-aldealab",
    "private": true,
    "version": "0.22.3",
    "description": "Frontend SPA for the Reservas Aldealab WordPress plugin.",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc --noEmit && vite build",
        "preview": "vite preview",
        "lint": "eslint \"frontend/**/*.{ts,tsx}\" --max-warnings=0",
        "lint:fix": "eslint \"frontend/**/*.{ts,tsx}\" --fix",
        "dev:admin": "vite --mode admin",
        "format": "prettier --write \"frontend/**/*.{ts,tsx,css,json}\"",
        "format:check": "prettier --check \"frontend/**/*.{ts,tsx,css,json}\"",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "prepare": "husky"
    },
    "dependencies": {
        "@fullcalendar/core": "^6.1.20",
        "@fullcalendar/daygrid": "^6.1.20",
        "@fullcalendar/interaction": "^6.1.20",
        "@fullcalendar/list": "^6.1.20",
        "@fullcalendar/multimonth": "^6.1.20",
        "@fullcalendar/react": "^6.1.20",
        "@fullcalendar/timegrid": "^6.1.20",
        "@tanstack/react-query": "^5.59.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "zod": "^3.23.8",
        "zustand": "^4.5.5"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.5.0",
        "@testing-library/react": "^16.0.1",
        "@testing-library/user-event": "^14.5.2",
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "@typescript-eslint/eslint-plugin": "^8.11.0",
        "@typescript-eslint/parser": "^8.11.0",
        "@vitejs/plugin-react": "^4.3.3",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-react": "^7.37.2",
        "eslint-plugin-react-hooks": "^5.0.0",
        "eslint-plugin-react-refresh": "^0.4.14",
        "husky": "^9.1.6",
        "jsdom": "^25.0.1",
        "lint-staged": "^15.2.10",
        "prettier": "^3.3.3",
        "typescript": "^5.6.3",
        "vite": "^5.4.10",
        "vitest": "^2.1.4"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "lint-staged": {
        "frontend/**/*.{ts,tsx}": [
            "eslint --fix --max-warnings=0",
            "prettier --write"
        ],
        "frontend/**/*.{css,json}": [
            "prettier --write"
        ],
        "{src,tests}/**/*.php": [
            "sh -c 'if [ -x ./vendor/bin/phpcs ]; then ./vendor/bin/phpcs --standard=phpcs.xml.dist \"$@\"; else echo \"  [skip] ./vendor/bin/phpcs not installed locally — CI enforces PHPCS on push.\"; fi' _"
        ]
    }
}
