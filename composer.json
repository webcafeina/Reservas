{
    "name": "webcafeina/reservas-aldealab",
    "description": "Sistema de reservas de salas para Aldealab (Cáceres): gestión autónoma con recurrencias RFC 5545, PDF oficial y notificaciones.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Webcafeína",
            "homepage": "https://webcafeina.com",
            "email": "info@webcafeina.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "ext-json": "*",
        "ext-pdo": "*",
        "simshaun/recurr": "^5.0",
        "mikehaertl/php-pdftk": "^0.13"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^1.10",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "squizlabs/php_codesniffer": "^3.9",
        "wp-coding-standards/wpcs": "^3.0",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "WebcafeinaReservas\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WebcafeinaReservas\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "phpcs --standard=phpcs.xml.dist",
        "lint:fix": "phpcbf --standard=phpcs.xml.dist",
        "stan": "phpstan analyse --configuration=phpstan.neon --memory-limit=1G",
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=Unit",
        "test:integration": "phpunit --testsuite=Integration"
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "7.4.33"
        },
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
