<?xml version="1.0"?>
<ruleset name="ReservasAldealab">
    <description>Coding standards for the Reservas Aldealab plugin.</description>

    <arg name="basepath" value="."/>
    <arg name="cache" value=".phpcs-cache"/>
    <arg name="colors"/>
    <arg name="extensions" value="php"/>
    <arg name="parallel" value="8"/>
    <arg name="tab-width" value="4"/>

    <!-- What to scan -->
    <file>reservas-aldealab.php</file>
    <file>src/</file>
    <file>tests/</file>

    <!-- What to exclude -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/assets/*</exclude-pattern>
    <exclude-pattern>*/frontend/*</exclude-pattern>

    <!-- Ruleset: WordPress -->
    <rule ref="WordPress">
        <!-- We use a PSR-4 autoloader, not filename conventions. -->
        <exclude name="WordPress.Files.FileName"/>
        <!-- Yoda conditions noise; we rely on type checks via PHPStan. -->
        <exclude name="WordPress.PHP.YodaConditions"/>
    </rule>

    <!-- WP compatibility: target WP 6.0 and up -->
    <config name="minimum_supported_wp_version" value="6.0"/>

    <!-- PHP compatibility: target PHP 7.4+ -->
    <rule ref="PHPCompatibilityWP"/>
    <config name="testVersion" value="7.4-"/>

    <!-- Text domain enforcement -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="reservas-aldealab"/>
            </property>
        </properties>
    </rule>

    <!-- Table prefix enforcement (we use $wpdb->prefix . 'reservas_') -->
    <rule ref="WordPress.DB.PreparedSQL"/>
    <rule ref="WordPress.DB.DirectDatabaseQuery">
        <!-- Our plugin has its own tables; direct queries are expected. -->
        <properties>
            <property name="customCacheTableList" type="array">
                <element value="reservas_bookings"/>
                <element value="reservas_booking_dates"/>
                <element value="reservas_user_profiles"/>
                <element value="reservas_booking_cpa_items"/>
                <element value="reservas_email_log"/>
            </property>
        </properties>
    </rule>
</ruleset>
